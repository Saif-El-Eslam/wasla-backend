NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
FRONTEND_ORIGIN=http://localhost:3000
PUBLIC_API_ORIGIN=http://localhost:4000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=240
AUTH_RATE_LIMIT_MAX=30
CODE_RATE_LIMIT_MAX=12
AUTHENTICATED_RATE_LIMIT_MAX=600
PUBLIC_ANALYTICS_RATE_LIMIT_MAX=120

# Runtime uses the transaction-mode pooler.
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma migrations use the session-mode pooler.
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
COOKIE_NAME=wasla_session

# Optional bootstrap admin. Use strong secrets in production.
SUPER_ADMIN_PHONE=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Wasla Platform Admin
WASLA_SALES_WHATSAPP=+201000000001

# Cloudinary powers the current direct image-upload flow.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Alternatively: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.1 # Lower values make extraction more deterministic
GEMINI_MAX_IMAGES_PER_EXTRACTION=2 # This will limit the number of images per extraction
GEMINI_MAX_INLINE_REQUEST_MB=8 # This will limit the size of the inline request
GEMINI_EXTRACTION_TIMEOUT_MS=600000  # 10 minutes -- timeout means that the extraction will be interrupted after 10 minutes
EXTRACTION_STALE_JOB_AFTER_MS=660000 # 11 minutes -- sweep means that a job that is older than 11 minutes will be deleted
EXTRACTION_STALE_SWEEP_INTERVAL_MS=300000 # 5 minutes -- sweep interval means that a sweep will be run every 5 minutes
GEMINI_HTTP_RETRY_ATTEMPTS=2 # controls HTTP attempts inside one durable attempt 
EXTRACTION_MAX_ATTEMPTS=3 # controls complete job attempts. The default is 3. Each durable attempt claims the job, reloads saved images, calls Gemini, and validates the response.
EXTRACTION_RETRY_BASE_DELAY_MS=5000 # used for adding random delay between attempts
EXTRACTION_WORKER_INTERVAL_MS=10000 # this means that the worker will run every 10 seconds
EXTRACTION_MANUAL_RETRY_WINDOW_MS=86400000 # 1 day
EXTRACTION_CLEANUP_INTERVAL_MS=3600000 # 1 hour
EXTRACTION_MAINTENANCE_MAX_JOBS=1
CRON_SECRET=replace-with-at-least-16-random-characters
