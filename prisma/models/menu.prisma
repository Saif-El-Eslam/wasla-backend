enum MenuTheme {
  CLASSIC
  MODERN
  MINIMAL
}

enum AnalyticsEventType {
  VENUE_VIEW
  MENU_VIEW
  CATEGORY_VIEW
  QR_SCAN
  WHATSAPP_CLICK
  CALL_CLICK
  MAPS_CLICK
  ITEM_VIEW
}

enum GuestFeedbackStatus {
  NEW
  REVIEWED
  ARCHIVED
}

enum ExtractionJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  APPROVED
  REJECTED
}

model Menu {
  id          String    @id @default(uuid())
  branchId    String    @unique
  theme       MenuTheme @default(MODERN)
  showPrices  Boolean   @default(true)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch          Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  categories      MenuCategory[]
  qrCode          MenuQrCode?
  analytics       MenuAnalytics?
  analyticsEvents AnalyticsEventLog[]
  guestFeedbacks  GuestFeedback[]
  extractionJobs  ExtractionJob[]

  @@index([branchId, publishedAt])
}

model GuestFeedback {
  id                    String              @id @default(uuid())
  venueId               String
  branchId              String
  menuId                String?
  rating                Int
  comment               String?
  guestName             String?
  guestPhone            String?
  status                GuestFeedbackStatus @default(NEW)
  locale                String?
  googleReviewOffered   Boolean             @default(false)
  googleReviewClickedAt DateTime?
  ownerNotifiedAt       DateTime?
  userAgent             String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  venue  Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  menu   Menu?  @relation(fields: [menuId], references: [id], onDelete: SetNull)

  @@index([venueId, createdAt])
  @@index([branchId, createdAt])
  @@index([rating, createdAt])
  @@index([status, createdAt])
  @@index([googleReviewClickedAt])
}

model ExtractionJob {
  id               String              @id @default(uuid())
  menuId           String
  branchId         String
  venueId          String
  requestedById    String?
  status           ExtractionJobStatus @default(PENDING)
  modelProvider    String              @default("google")
  modelName        String
  imageCount       Int                 @default(0)
  attemptCount     Int                 @default(0)
  maxAttempts      Int                 @default(3)
  nextAttemptAt    DateTime            @default(now())
  lastAttemptAt    DateTime?
  retryExpiresAt   DateTime?
  cleanedUpAt      DateTime?
  providerResponseId String?
  rawModelResponse String?
  extractedMenu    Json?
  confidenceScore  Float?
  warnings         String[]            @default([])
  errors           String[]            @default([])
  approvedAt       DateTime?
  rejectedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  menu        Menu                 @relation(fields: [menuId], references: [id], onDelete: Cascade)
  inputImages ExtractionJobImage[]

  @@index([venueId, createdAt])
  @@index([branchId, createdAt])
  @@index([menuId, status])
  @@index([status, nextAttemptAt])
  @@index([status, retryExpiresAt])
}

model ExtractionJobImage {
  id        String   @id @default(uuid())
  jobId     String
  sortOrder Int
  mimeType  String
  data      Bytes
  createdAt DateTime @default(now())

  job ExtractionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, sortOrder])
  @@index([jobId])
}

model MenuCategory {
  id          String   @id @default(uuid())
  menuId      String
  name        Json
  description Json?
  imageUrl    String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menu            Menu                @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items           MenuItem[]
  analyticsEvents AnalyticsEventLog[]

  @@index([menuId, sortOrder])
}

model MenuItem {
  id          String   @id @default(uuid())
  categoryId  String
  name        Json
  description Json?
  price       Decimal? @db.Decimal(10, 2)
  imageUrl    String?
  tags        String[] @default([])
  calories    Int?
  available   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category        MenuCategory        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  prices          MenuItemPrice[]
  analyticsEvents AnalyticsEventLog[]

  @@index([categoryId, sortOrder])
}

model MenuItemPrice {
  id        String   @id @default(uuid())
  itemId    String
  label     String
  price     Decimal  @db.Decimal(10, 2)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, label])
  @@index([itemId, sortOrder])
}

model MenuQrCode {
  id        String   @id @default(uuid())
  menuId    String   @unique
  shortCode String   @unique
  targetUrl String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)
}

model MenuAnalytics {
  id             String   @id @default(uuid())
  menuId         String   @unique
  viewCount      Int      @default(0)
  qrScanCount    Int      @default(0)
  whatsappClicks Int      @default(0)
  callClicks     Int      @default(0)
  mapsClicks     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)
}

model AnalyticsEventLog {
  id         String             @id @default(uuid())
  venueId    String
  branchId   String
  menuId     String?
  categoryId String?
  itemId     String?
  eventType  AnalyticsEventType
  createdAt  DateTime           @default(now())

  venue    Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  branch   Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  menu     Menu?         @relation(fields: [menuId], references: [id], onDelete: SetNull)
  category MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  item     MenuItem?     @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([venueId, createdAt])
  @@index([branchId, createdAt])
  @@index([menuId, createdAt])
  @@index([eventType, createdAt])
}

